# Copy this file to .env and fill in real values. Never commit .env itself.

# Postgres connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/nba_fantasy

# balldontlie.io API key (Free tier: 5 requests/min, covers teams/players/games)
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here

# Delay between paginated requests, in milliseconds. Free tier = 5 req/min,
# so keep this above 12000ms (12s) to avoid 429 rate-limit errors.
BALLDONTLIE_REQUEST_DELAY_MS=13000

# Cron schedule for src/cronScheduler.js (standard 5-field cron syntax).
# Default: 9:00 AM daily, US Eastern time (games from the prior night are
# all "Final" well before this).
CRON_EXPRESSION=0 9 * * *
CRON_TIMEZONE=America/New_York
